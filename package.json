{
  "name": "marketing-service",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @marketing-service/database drizzle-kit generate",
    "db:migrate": "pnpm --filter @marketing-service/database drizzle-kit migrate",
    "db:seed:campaign-presets": "pnpm --filter @marketing-service/database build && pnpm --filter @marketing-service/database seed:campaign-presets",
    "db:studio": "pnpm --filter @marketing-service/database drizzle-kit studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "turbo": "^2.4.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@nestjs/core",
      "@swc/core",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
